<section class="password">
  <div class="password__card">
    <p class="kicker">Bald verfügbar</p>
    <h1>{{ shop.name }}</h1>
    {% if section.settings.text != blank %}
      <p class="password__text">{{ section.settings.text }}</p>
    {% endif %}

    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <div class="password__row">
        <label class="visually-hidden" for="Password">Passwort</label>
        <input type="password" name="password" id="Password" placeholder="Passwort" autocomplete="current-password">
        <button type="submit" class="btn">Öffnen</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Passwortseite",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Wir arbeiten gerade an etwas Gutem. Bis gleich!"
    }
  ]
}
{% endschema %}
