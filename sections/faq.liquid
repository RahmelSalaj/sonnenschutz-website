<section class="faq section-pad section-soft">
  <div class="container faq__container">
    <div class="section-head">
      {% if section.settings.kicker != blank %}
        <p class="kicker">{{ section.settings.kicker }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="faq__list">
      {% for block in section.blocks %}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.question }}</span>
            <svg class="faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq__answer rte">{{ block.settings.answer }}</div>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kleine Überzeile",
      "default": "Gut zu wissen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Frage",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Frage",
          "default": "Deine Frage?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Antwort",
          "default": "<p>Deine Antwort.</p>"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
