<section class="hero{% if section.settings.image == blank %} hero--no-image{% endif %}">
  <div class="container hero__inner">
    <div class="hero__content">
      {% if section.settings.kicker != blank %}
        <p class="kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      <h1 class="hero__heading">{{ section.settings.heading }}</h1>

      {% if section.settings.text != blank %}
        <p class="hero__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="hero__actions">
        {% if section.settings.button_label != blank %}
          <a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
        {% endif %}
      </div>

      {% if section.settings.note != blank %}
        <p class="hero__note">{{ section.settings.note }}</p>
      {% endif %}
    </div>

    <div class="hero__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', class: 'hero__img', widths: '600, 900, 1400' }}
      {% else %}
        <div class="media-placeholder" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8"/>
          </svg>
          <span>Produktbild folgt</span>
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kleine Überzeile",
      "default": "Faltbarer Sonnenschutz für die Frontscheibe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Dein Auto bleibt kühl. Auch wenn die Sonne brennt."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "In Sekunden wie ein Regenschirm hinter der Frontscheibe aufgespannt: reflektiert Sonnenlicht und UV-Strahlen und schützt Cockpit, Lenkrad und Sitze vor Hitze."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Sonnenschutz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Hinweiszeile unter dem Button",
      "default": "In zwei Größen — passend für die meisten Fahrzeuge"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild",
      "info": "Optional — ohne Bild wird ein Platzhalter angezeigt."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
