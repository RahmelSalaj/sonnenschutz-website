<section class="hero-banner">
  {% if section.settings.image %}
    {{
      section.settings.image
      | image_url: width: 3000
      | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        class: 'hero-banner__img',
        widths: '750, 1100, 1500, 1780',
        sizes: '100vw'
    }}
  {% endif %}
  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <div class="container hero-banner__content">
    {% if section.settings.kicker != blank %}
      <p class="kicker">{{ section.settings.kicker }}</p>
    {% endif %}

    <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>

    {% if section.settings.text != blank %}
      <p class="hero-banner__text">{{ section.settings.text }}</p>
    {% endif %}

    <div class="hero-banner__actions">
      {% if section.settings.button_label != blank %}
        <a class="btn btn--light" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>

    {% if section.settings.note != blank %}
      <p class="hero-banner__note">{{ section.settings.note }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kleine Überzeile",
      "default": "Faltbarer Sonnenschutz für die Frontscheibe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Nie wieder am Lenkrad verbrennen."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "In 2 Sekunden wie ein Regenschirm hinter der Frontscheibe aufgespannt: reflektiert Sonnenlicht und UV-Strahlen und schützt Cockpit, Lenkrad und Sitze."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Zum Sonnenschutz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Hinweiszeile unter dem Button",
      "default": "In zwei Größen — passend für die meisten Fahrzeuge"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild",
      "info": "Wird vollflächig als Hintergrund angezeigt. Ohne Bild: dunkler Hintergrund."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
