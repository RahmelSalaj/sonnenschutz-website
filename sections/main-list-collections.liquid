<section class="collection section-pad">
  <div class="container">
    <header class="section-head">
      <h1>Kategorien</h1>
    </header>

    {% paginate collections by 12 %}
      <div class="product-grid">
        {% for collection in collections %}
          <a href="{{ collection.url }}" class="product-card">
            <div class="product-card__media">
              {% if collection.featured_image %}
                {{ collection.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', class: 'product-card__img' }}
              {% else %}
                <div class="media-placeholder media-placeholder--small" aria-hidden="true">
                  <span>{{ collection.title | slice: 0 }}</span>
                </div>
              {% endif %}
            </div>
            <h3 class="product-card__title">{{ collection.title }}</h3>
          </a>
        {% endfor %}
      </div>
      <div class="pagination-wrap">{{ paginate | default_pagination }}</div>
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Kollektionsliste",
  "settings": []
}
{% endschema %}
