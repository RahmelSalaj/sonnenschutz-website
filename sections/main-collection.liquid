<section class="collection section-pad">
  <div class="container">
    <header class="section-head">
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="rte">{{ collection.description }}</div>
      {% endif %}
    </header>

    {% paginate collection.products by 12 %}
      {% if collection.products.size == 0 %}
        <p class="empty-note">Hier liegen noch keine Produkte.</p>
      {% else %}
        <div class="product-grid">
          {% for product in collection.products %}
            {% render 'product-card', card_product: product %}
          {% endfor %}
        </div>
        <div class="pagination-wrap">{{ paginate | default_pagination }}</div>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% schema %}
{
  "name": "Kollektion",
  "settings": []
}
{% endschema %}
