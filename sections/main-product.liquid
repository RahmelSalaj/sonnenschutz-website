{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product section-pad" id="MainProduct-{{ section.id }}">
  <div class="container product__grid">

    <div class="product__media">
      {% if product.media.size > 0 %}
        <div class="product__gallery">
          <div class="product__main-image">
            <img
              id="MainImage-{{ section.id }}"
              src="{{ current_variant.featured_media | default: product.featured_media | image_url: width: 1000 }}"
              alt="{{ product.featured_media.alt | default: product.title | escape }}"
              loading="eager"
            >
          </div>
          {% if product.media.size > 1 %}
            <div class="product__thumbs">
              {% for media in product.media %}
                <button
                  type="button"
                  class="product__thumb"
                  data-full="{{ media | image_url: width: 1000 }}"
                  aria-label="Bild {{ forloop.index }} anzeigen"
                >
                  <img src="{{ media | image_url: width: 180 }}" alt="{{ media.alt | escape }}" loading="lazy">
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% else %}
        <div class="media-placeholder" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8"/></svg>
          <span>Produktbilder folgen in Kürze</span>
        </div>
      {% endif %}
    </div>

    <div class="product__info">
      {% if product.vendor != blank and section.settings.show_vendor %}
        <p class="kicker">{{ product.vendor }}</p>
      {% endif %}

      <h1 class="product__title">{{ product.title }}</h1>

      <p class="product__price">
        <span id="Price-{{ section.id }}">{{ current_variant.price | money }}</span>
        {% if current_variant.compare_at_price > current_variant.price %}
          <s id="ComparePrice-{{ section.id }}">{{ current_variant.compare_at_price | money }}</s>
        {% endif %}
      </p>
      <p class="product__tax-note">inkl. MwSt., zzgl. <a href="/pages/versand">Versandkosten</a></p>

      {% form 'product', product, id: 'ProductForm', class: 'product__form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <fieldset class="product__option" data-option-index="{{ forloop.index0 }}">
              <legend>{{ option.name }}</legend>
              <div class="option-pills">
                {% assign option_index = forloop.index %}
                {% for value in option.values %}
                  <input
                    type="radio"
                    id="Option-{{ section.id }}-{{ option_index }}-{{ forloop.index }}"
                    name="options[{{ option.name | escape }}]"
                    value="{{ value | escape }}"
                    {% if option.selected_value == value %}checked{% endif %}
                  >
                  <label for="Option-{{ section.id }}-{{ option_index }}-{{ forloop.index }}">{{ value }}</label>
                {% endfor %}
              </div>
            </fieldset>
          {% endfor %}
        {% endunless %}

        <div class="product__buy-row">
          <div class="qty">
            <label class="visually-hidden" for="Quantity-{{ section.id }}">Menge</label>
            <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
          </div>
          <button
            type="submit"
            name="add"
            id="AddToCart-{{ section.id }}"
            class="btn btn--full"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}
          </button>
        </div>
      {% endform %}

      {% if section.blocks.size > 0 %}
        <ul class="product__trust">
          {% for block in section.blocks %}
            <li {{ block.shopify_attributes }}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      <div class="product__description rte">
        {{ product.description }}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('MainProduct-{{ section.id }}');
    if (!root) return;

    var variants = {{ product.variants | json }};
    var form = root.querySelector('form[action*="/cart/add"]');
    var priceEl = document.getElementById('Price-{{ section.id }}');
    var compareEl = document.getElementById('ComparePrice-{{ section.id }}');
    var buttonEl = document.getElementById('AddToCart-{{ section.id }}');
    var mainImage = document.getElementById('MainImage-{{ section.id }}');

    function money(cents) {
      return (cents / 100).toFixed(2).replace('.', ',') + ' {{ cart.currency.symbol }}';
    }

    function selectedOptions() {
      var fieldsets = root.querySelectorAll('.product__option');
      return Array.prototype.map.call(fieldsets, function (fs) {
        var checked = fs.querySelector('input:checked');
        return checked ? checked.value : null;
      });
    }

    if (form) {
      form.addEventListener('change', function (event) {
        if (!event.target.name || event.target.name.indexOf('options[') !== 0) return;

        var opts = selectedOptions();
        var match = variants.find(function (variant) {
          return variant.options.every(function (value, index) {
            return value === opts[index];
          });
        });

        if (!match) return;

        form.querySelector('input[name="id"]').value = match.id;

        if (priceEl) priceEl.textContent = money(match.price);
        if (compareEl) {
          compareEl.style.display = match.compare_at_price > match.price ? '' : 'none';
          if (match.compare_at_price) compareEl.textContent = money(match.compare_at_price);
        }
        if (buttonEl) {
          buttonEl.disabled = !match.available;
          buttonEl.textContent = match.available ? 'In den Warenkorb' : 'Ausverkauft';
        }
        if (mainImage && match.featured_media && match.featured_media.preview_image) {
          mainImage.src = match.featured_media.preview_image.src;
        }

        var url = new URL(window.location.href);
        url.searchParams.set('variant', match.id);
        window.history.replaceState({}, '', url.toString());
      });
    }

    root.querySelectorAll('.product__thumb').forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        if (mainImage) mainImage.src = thumb.dataset.full;
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Produktseite",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Anbieter anzeigen",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Vertrauens-Punkt",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Sichere Bezahlung"
        }
      ]
    }
  ],
  "max_blocks": 5
}
{% endschema %}
