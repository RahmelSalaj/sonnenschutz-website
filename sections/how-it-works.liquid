<section class="steps section-pad" id="so-funktionierts">
  <div class="container">
    <div class="section-head">
      {% if section.settings.kicker != blank %}
        <p class="kicker">{{ section.settings.kicker }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <ol class="steps__list">
      {% for block in section.blocks %}
        <li class="step" {{ block.shopify_attributes }}>
          <span class="step__number" aria-hidden="true">{{ forloop.index }}</span>
          <div>
            {% if block.settings.heading != blank %}
              <h3 class="step__heading">{{ block.settings.heading }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="step__text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "So funktioniert's",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kleine Überzeile",
      "default": "Kinderleicht"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "So funktioniert's"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Schritt",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Schritt"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "So funktioniert's",
      "blocks": [
        { "type": "step" },
        { "type": "step" },
        { "type": "step" }
      ]
    }
  ]
}
{% endschema %}
