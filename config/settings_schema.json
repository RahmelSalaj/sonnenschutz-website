[
  {
    "name": "theme_info",
    "theme_name": "Sunshade",
    "theme_version": "1.0.0",
    "theme_author": "RahmelSalaj",
    "theme_documentation_url": "https://github.com/RahmelSalaj",
    "theme_support_url": "https://github.com/RahmelSalaj"
  },
  {
    "name": "Farben",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Hintergrund",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_bg_soft",
        "label": "Hintergrund für abgesetzte Abschnitte",
        "default": "#f5f7fa"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#18202e"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Akzentfarbe (Buttons und Links)",
        "default": "#e8590c"
      },
      {
        "type": "color",
        "id": "color_accent_text",
        "label": "Text auf Akzentfarbe",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Typografie",
    "settings": [
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Schriftart",
        "default": "work_sans_n4"
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Optional — ohne Logo wird der Shop-Name als Schriftzug angezeigt."
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo-Breite",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 140
      }
    ]
  }
]
